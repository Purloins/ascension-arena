# ─────────────────────────────────────────
# Copy this to .env.local and fill in values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────

# ── Database (Neon via Vercel) ────────────
# In Vercel: Storage → your Neon database → .env.local / Quickstart tab.
# Use the POOLED connection string for DATABASE_URL.
# Use the UNPOOLED / direct connection string for DIRECT_URL.
# (Neon often names these DATABASE_URL and DATABASE_URL_UNPOOLED.)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ── NextAuth ──────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Local dev URL (no trailing slash). On Vercel this is set automatically.
NEXTAUTH_URL=http://localhost:3000

# ── osu! OAuth ────────────────────────────
# From osu.ppy.sh/home/account/edit → OAuth → New OAuth Application.
# Callback URL to register:
#   Local:      http://localhost:3000/api/auth/callback/osu
#   Production:  https://your-domain.vercel.app/api/auth/callback/osu
OSU_CLIENT_ID=your-osu-client-id
OSU_CLIENT_SECRET=your-osu-client-secret

# ── Admin ─────────────────────────────────
# Your User.id (from the database, after first login). Comma-separate multiple.
ADMIN_USER_IDS=

# ── Feature flags ─────────────────────────
NEXT_PUBLIC_REGISTRATION_OPEN=false
NEXT_PUBLIC_ELEMENT_ROLL_DONE=false
